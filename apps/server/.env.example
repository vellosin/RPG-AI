PORT=8787
HOST=127.0.0.1
JAN_BASE_URL=http://127.0.0.1:1337/v1
JAN_MODEL=Qwen3_5-9B-IQ4_XS
OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5:7b
IMAGE_BASE_URL=http://127.0.0.1:7860
IMAGE_MODEL=
# auto checks ComfyUI first, then Python SDXL, Automatic1111 and OpenAI-compatible APIs.
IMAGE_PROVIDER=auto
IMAGE_COMFY_URL=http://127.0.0.1:8188
# Optional. If empty, the server asks ComfyUI for the first available checkpoint.
# Example portrait-friendly checkpoint for ComfyUI.
IMAGE_COMFY_CHECKPOINT=RealVisXL_V5.0_fp16.safetensors
IMAGE_PYTHON_EXECUTABLE=
# Directory containing sdxl_runtime.py and the SDXL model folder.
IMAGE_RUNTIME_DIR=C:/path/to/sdxl-runtime
IMAGE_MCP_URL=http://127.0.0.1:8765/mcp
# Keep true on CPU. Set false only when using CUDA/GPU or when quality matters more than speed.
IMAGE_FAST_MODE=true
